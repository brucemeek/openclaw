agent.arcanedge.ai {
    reverse_proxy 127.0.0.1:18789 {
        header_up Host {host}
        header_up X-Real-IP {remote}
        header_up X-Forwarded-For {remote}
        header_up X-Forwarded-Proto {scheme}

        transport http {
            keepalive 30s
        }
    }
    encode gzip
    log {
        output file /var/log/caddy/agent.arcanedge.ai.log
    }
}

